<Window x:Class="SubtitleHider.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubtitleHider"
        mc:Ignorable="d"
        Title="设置透明度" Height="200" Width="160"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="True">
    <StackPanel Margin="10" VerticalAlignment="Center">
        <TextBlock Text="透明度 (0-1):" Margin="0,0,0,5"/>
        <TextBox x:Name="TextBoxOpacityValue" Text="1.0" Margin="0,0,0,10"/>
        <Button x:Name="ButtonSetOpacity" Content="设置" Margin="0,0,0,5" Click="ButtonSetOpacity_Click"/>
        <Button x:Name="ButtonShowHider" Content="显示 (1)" Margin="0,0,0,5" Click="ButtonShowHider_Click"/>
        <Button x:Name="ButtonHideHider" Content="隐藏 (0)" Margin="0,0,0,5" Click="ButtonHideHider_Click"/>
    </StackPanel>
</Window>
